{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charmbracelet/crush/internal/config/config",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Agent": {
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "primary",
            "subagent",
            "all"
          ],
          "description": "Where this agent can run",
          "default": "all"
        },
        "disabled": {
          "type": "boolean"
        },
        "model": {
          "type": "string",
          "enum": [
            "large",
            "small"
          ],
          "description": "The model type to use for this agent",
          "default": "large"
        },
        "allowed_tools": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "allowed_mcp": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object"
        },
        "task_governance": {
          "$ref": "#/$defs/TaskGovernance",
          "description": "Task graph execution policy for this agent"
        },
        "context_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "model"
      ]
    },
    "Attribution": {
      "properties": {
        "trailer_style": {
          "type": "string",
          "enum": [
            "none",
            "co-authored-by",
            "assisted-by"
          ],
          "description": "Style of attribution trailer to add to commits",
          "default": "assisted-by"
        },
        "co_authored_by": {
          "type": "boolean",
          "description": "Deprecated: use trailer_style instead",
          "deprecated": true
        },
        "generated_with": {
          "type": "boolean",
          "description": "Add Generated with Crush line to commit messages and issues and PRs",
          "default": true
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "AutoMode": {
      "properties": {
        "environment": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Additional environment facts injected into Auto Mode classifier prompts"
        },
        "block_rules": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Additional block rules for Auto Mode guards"
        },
        "allow_exceptions": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Additional allow-list exceptions for Auto Mode guards"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "CommandConfig": {
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "passthrough": {
          "type": "boolean"
        },
        "passthrough_field": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "command"
      ]
    },
    "Completions": {
      "properties": {
        "max_depth": {
          "type": "integer",
          "description": "Maximum depth for the ls tool",
          "default": 0,
          "examples": [
            10
          ]
        },
        "max_items": {
          "type": "integer",
          "description": "Maximum number of items to return for the ls tool",
          "default": 1000,
          "examples": [
            100
          ]
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Config": {
      "properties": {
        "$schema": {
          "type": "string"
        },
        "models": {
          "additionalProperties": {
            "$ref": "#/$defs/SelectedModel"
          },
          "type": "object",
          "description": "Model configurations for different model types"
        },
        "providers": {
          "$ref": "#/$defs/Map[string,github.com/charmbracelet/crush/internal/config.ProviderConfig]",
          "description": "AI provider configurations"
        },
        "mcp": {
          "$ref": "#/$defs/MCPs",
          "description": "Model Context Protocol server configurations"
        },
        "lsp": {
          "$ref": "#/$defs/LSPs",
          "description": "Language Server Protocol configurations"
        },
        "options": {
          "$ref": "#/$defs/Options",
          "description": "General application options"
        },
        "permissions": {
          "$ref": "#/$defs/Permissions",
          "description": "Permission settings for tool usage"
        },
        "tools": {
          "$ref": "#/$defs/Tools",
          "description": "Tool configurations"
        },
        "hooks": {
          "items": {
            "$ref": "#/$defs/HookConfig"
          },
          "type": "array",
          "description": "Tool execution hooks (PreToolUse)"
        },
        "plugins": {
          "items": {
            "$ref": "#/$defs/PluginConfig"
          },
          "type": "array",
          "description": "External command plugins for chat or tool lifecycle customization"
        },
        "agents": {
          "additionalProperties": {
            "$ref": "#/$defs/Agent"
          },
          "type": "object",
          "description": "Named agent configurations"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "tools"
      ]
    },
    "HTTPConfig": {
      "properties": {
        "url": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "url"
      ]
    },
    "HookConfig": {
      "properties": {
        "name": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "events": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer"
        },
        "command": {
          "$ref": "#/$defs/CommandConfig"
        },
        "http": {
          "$ref": "#/$defs/HTTPConfig"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "events",
        "type"
      ]
    },
    "LSPConfig": {
      "properties": {
        "disabled": {
          "type": "boolean",
          "description": "Whether this LSP server is disabled",
          "default": false
        },
        "command": {
          "type": "string",
          "description": "Command to execute for the LSP server",
          "examples": [
            "gopls"
          ]
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Arguments to pass to the LSP server command"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "Environment variables to set to the LSP server command"
        },
        "filetypes": {
          "items": {
            "type": "string",
            "examples": [
              "go",
              "mod",
              "rs",
              "c",
              "js",
              "ts"
            ]
          },
          "type": "array",
          "description": "File types this LSP server handles"
        },
        "root_markers": {
          "items": {
            "type": "string",
            "examples": [
              "go.mod",
              "package.json",
              "Cargo.toml"
            ]
          },
          "type": "array",
          "description": "Files or directories that indicate the project root"
        },
        "init_options": {
          "type": "object",
          "description": "Initialization options passed to the LSP server during initialize request"
        },
        "options": {
          "type": "object",
          "description": "LSP server-specific settings passed during initialization"
        },
        "timeout": {
          "type": "integer",
          "description": "Timeout in seconds for LSP server initialization",
          "default": 30,
          "examples": [
            60,
            120
          ]
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "LSPs": {
      "additionalProperties": {
        "$ref": "#/$defs/LSPConfig"
      },
      "type": "object"
    },
    "MCPConfig": {
      "properties": {
        "command": {
          "type": "string",
          "description": "Command to execute for stdio MCP servers",
          "examples": [
            "npx"
          ]
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "Environment variables to set for the MCP server"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Arguments to pass to the MCP server command"
        },
        "type": {
          "type": "string",
          "enum": [
            "stdio",
            "sse",
            "http"
          ],
          "description": "Type of MCP connection",
          "default": "stdio"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL for HTTP or SSE MCP servers",
          "examples": [
            "http://localhost:3000/mcp"
          ]
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether this MCP server is disabled",
          "default": false
        },
        "disabled_tools": {
          "items": {
            "type": "string",
            "examples": [
              "get-library-doc"
            ]
          },
          "type": "array",
          "description": "List of tools from this MCP server to disable"
        },
        "timeout": {
          "type": "integer",
          "description": "Timeout in seconds for MCP server connections",
          "default": 15,
          "examples": [
            30,
            60,
            120
          ]
        },
        "oauth": {
          "$ref": "#/$defs/MCPOAuthConfig",
          "description": "OAuth configuration for HTTP MCP servers"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "HTTP headers for HTTP/SSE MCP servers"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type"
      ]
    },
    "MCPOAuthAuthServer": {
      "properties": {
        "issuer": {
          "type": "string",
          "format": "uri",
          "description": "OAuth authorization server issuer URL"
        },
        "authorization_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "OAuth authorization endpoint for the MCP server"
        },
        "token_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "OAuth token endpoint for the MCP server"
        },
        "registration_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "OAuth dynamic client registration endpoint for the MCP server"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MCPOAuthConfig": {
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable OAuth authentication for HTTP MCP servers",
          "default": false
        },
        "client_name": {
          "type": "string",
          "description": "Client name used during MCP OAuth registration",
          "examples": [
            "Crush"
          ]
        },
        "redirect_url": {
          "type": "string",
          "format": "uri",
          "description": "Loopback redirect URL override for MCP OAuth callbacks",
          "examples": [
            "http://127.0.0.1:8913/callback"
          ]
        },
        "client_id": {
          "type": "string",
          "description": "Pre-registered OAuth client ID for the MCP server"
        },
        "client_secret": {
          "type": "string",
          "description": "Pre-registered OAuth client secret for the MCP server"
        },
        "token": {
          "$ref": "#/$defs/Token",
          "description": "Persisted OAuth token for the MCP server"
        },
        "registration": {
          "$ref": "#/$defs/MCPOAuthRegistration",
          "description": "Persisted OAuth client registration for the MCP server"
        },
        "auth_server": {
          "$ref": "#/$defs/MCPOAuthAuthServer",
          "description": "Discovered OAuth authorization server metadata for the MCP server"
        },
        "resource": {
          "type": "string",
          "format": "uri",
          "description": "Protected resource identifier for the MCP server"
        },
        "scopes": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "OAuth scopes granted for the MCP server"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MCPOAuthRegistration": {
      "properties": {
        "client_id": {
          "type": "string",
          "description": "Registered OAuth client ID for the MCP server"
        },
        "client_secret": {
          "type": "string",
          "description": "Registered OAuth client secret for the MCP server"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "MCPs": {
      "additionalProperties": {
        "$ref": "#/$defs/MCPConfig"
      },
      "type": "object"
    },
    "Map[string,github.com/charmbracelet/crush/internal/config.ProviderConfig]": {
      "properties": {},
      "additionalProperties": false,
      "type": "object"
    },
    "Options": {
      "properties": {
        "context_paths": {
          "items": {
            "type": "string",
            "examples": [
              ".cursorrules",
              "CRUSH.md"
            ]
          },
          "type": "array",
          "description": "Paths to files containing context information for the AI"
        },
        "skills_paths": {
          "items": {
            "type": "string",
            "examples": [
              "~/.config/crush/skills",
              "./skills"
            ]
          },
          "type": "array",
          "description": "Paths to directories containing Agent Skills (folders with SKILL.md files)"
        },
        "tui": {
          "$ref": "#/$defs/TUIOptions",
          "description": "Terminal user interface options"
        },
        "preferred_permission_mode": {
          "type": "string",
          "enum": [
            "default",
            "auto",
            "yolo"
          ],
          "description": "Default interactive permission mode for new sessions",
          "default": "auto"
        },
        "debug": {
          "type": "boolean",
          "description": "Enable debug logging",
          "default": false
        },
        "debug_lsp": {
          "type": "boolean",
          "description": "Enable debug logging for LSP servers",
          "default": false
        },
        "disable_auto_summarize": {
          "type": "boolean",
          "description": "Disable automatic conversation summarization",
          "default": false
        },
        "data_directory": {
          "type": "string",
          "description": "Directory for storing project-scoped application data (defaults to .crush in the working directory; falls back to a safe global workspace path when startup cwd is unsafe)",
          "default": ".crush",
          "examples": [
            ".crush"
          ]
        },
        "disabled_tools": {
          "items": {
            "type": "string",
            "examples": [
              "bash",
              "sourcegraph"
            ]
          },
          "type": "array",
          "description": "List of built-in tools to disable and hide from the agent"
        },
        "disable_provider_auto_update": {
          "type": "boolean",
          "description": "Disable providers auto-update",
          "default": false
        },
        "disable_default_providers": {
          "type": "boolean",
          "description": "Ignore all default/embedded providers. When enabled",
          "default": false
        },
        "attribution": {
          "$ref": "#/$defs/Attribution",
          "description": "Attribution settings for generated content"
        },
        "disable_metrics": {
          "type": "boolean",
          "description": "Disable sending metrics",
          "default": false
        },
        "initialize_as": {
          "type": "string",
          "description": "Name of the context file to create/update during project initialization",
          "default": "AGENTS.md",
          "examples": [
            "AGENTS.md",
            "CRUSH.md",
            "CLAUDE.md",
            "docs/LLMs.md"
          ]
        },
        "auto_lsp": {
          "type": "boolean",
          "description": "Automatically setup LSPs based on root markers",
          "default": true
        },
        "progress": {
          "type": "boolean",
          "description": "Show indeterminate progress updates during long operations",
          "default": true
        },
        "disable_notifications": {
          "type": "boolean",
          "description": "Disable desktop notifications",
          "default": false
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Permissions": {
      "properties": {
        "allowed_tools": {
          "items": {
            "type": "string",
            "examples": [
              "bash",
              "view"
            ]
          },
          "type": "array",
          "description": "List of tools that don't require permission prompts"
        },
        "fail_closed_on_classifier_error": {
          "type": "boolean",
          "description": "Block permission-requiring actions when Auto Mode permission classification is unavailable instead of falling back to manual confirmation",
          "default": false
        },
        "auto_mode": {
          "$ref": "#/$defs/AutoMode",
          "description": "Auto Mode policy customization"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "PluginConfig": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique plugin name",
          "examples": [
            "morph_compact"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "command"
          ],
          "description": "Plugin transport type",
          "default": "command"
        },
        "mode": {
          "type": "string",
          "enum": [
            "transient"
          ],
          "description": "transient spawns a new process per call; persistent reuses a long-running process over stdio",
          "default": "transient"
        },
        "command": {
          "type": "string",
          "description": "Command used to invoke the external plugin",
          "examples": [
            "node"
          ]
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Arguments passed to the plugin command"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "Environment variables passed to the plugin command"
        },
        "hooks": {
          "items": {
            "type": "string",
            "examples": [
              "[\"chat_messages_transform\""
            ]
          },
          "type": "array",
          "description": "Enabled plugin hooks"
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Timeout in milliseconds for each plugin invocation",
          "examples": [
            60000
          ]
        },
        "cwd": {
          "type": "string",
          "description": "Working directory for the plugin command"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "command"
      ]
    },
    "SelectedModel": {
      "properties": {
        "model": {
          "type": "string",
          "description": "The model ID as used by the provider API",
          "examples": [
            "gpt-4o"
          ]
        },
        "provider": {
          "type": "string",
          "description": "The model provider ID that matches a key in the providers config",
          "examples": [
            "openai"
          ]
        },
        "max_tokens": {
          "type": "integer",
          "maximum": 200000,
          "description": "Maximum number of tokens for model responses",
          "examples": [
            4096
          ]
        },
        "temperature": {
          "type": "number",
          "maximum": 1,
          "minimum": 0,
          "description": "Sampling temperature",
          "examples": [
            0.7
          ]
        },
        "top_p": {
          "type": "number",
          "maximum": 1,
          "minimum": 0,
          "description": "Top-p (nucleus) sampling parameter",
          "examples": [
            0.9
          ]
        },
        "top_k": {
          "type": "integer",
          "description": "Top-k sampling parameter"
        },
        "frequency_penalty": {
          "type": "number",
          "description": "Frequency penalty to reduce repetition"
        },
        "presence_penalty": {
          "type": "number",
          "description": "Presence penalty to increase topic diversity"
        },
        "reasoning_effort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "description": "Deprecated: Use model's default_reasoning_effort in provider config instead"
        },
        "think": {
          "type": "boolean",
          "description": "Enable thinking/reasoning mode for models that support it (applies to all providers)"
        },
        "provider_options": {
          "type": "object",
          "description": "Deprecated: Use model's options.provider_options in provider config instead"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "model",
        "provider"
      ]
    },
    "TUIOptions": {
      "properties": {
        "compact_mode": {
          "type": "boolean",
          "description": "Enable compact mode for the TUI interface",
          "default": false
        },
        "diff_mode": {
          "type": "string",
          "enum": [
            "unified",
            "split"
          ],
          "description": "Diff mode for the TUI interface"
        },
        "completions": {
          "$ref": "#/$defs/Completions",
          "description": "Completions UI options"
        },
        "transparent": {
          "type": "boolean",
          "description": "Enable transparent background for the TUI interface",
          "default": false
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "completions"
      ]
    },
    "TaskGovernance": {
      "properties": {
        "max_concurrent": {
          "type": "integer",
          "description": "Maximum number of task graph tasks of this agent type to run concurrently",
          "examples": [
            2
          ]
        },
        "timeout_seconds": {
          "type": "integer",
          "description": "Maximum number of seconds each task graph task may run before timing out",
          "examples": [
            300
          ]
        },
        "retry_budget": {
          "type": "integer",
          "description": "Number of retry attempts allowed after a task graph task fails",
          "examples": [
            2
          ]
        },
        "graph_timeout_seconds": {
          "type": "integer",
          "description": "Maximum number of seconds the entire task graph may run before remaining tasks are canceled",
          "examples": [
            900
          ]
        },
        "fail_fast": {
          "type": "boolean",
          "description": "Stop launching new task graph work after the first task failure",
          "default": false
        },
        "runtime_budget_seconds": {
          "type": "integer",
          "description": "Maximum number of seconds a shared runtime budget may remain active across delegated work",
          "examples": [
            600
          ]
        },
        "failure_budget": {
          "type": "integer",
          "description": "Maximum number of failures allowed within the configured failure domain before remaining delegated work is canceled",
          "examples": [
            3
          ]
        },
        "failure_domain": {
          "type": "string",
          "description": "Logical failure domain name shared by related delegated work",
          "examples": [
            "task_graph"
          ]
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Token": {
      "properties": {
        "access_token": {
          "type": "string"
        },
        "refresh_token": {
          "type": "string"
        },
        "expires_in": {
          "type": "integer"
        },
        "expires_at": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "access_token",
        "refresh_token",
        "expires_in",
        "expires_at"
      ]
    },
    "ToolGrep": {
      "properties": {
        "timeout": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ToolLs": {
      "properties": {
        "max_depth": {
          "type": "integer",
          "description": "Maximum depth for the ls tool",
          "default": 0,
          "examples": [
            10
          ]
        },
